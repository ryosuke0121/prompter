{
  "name": "prompter",
  "version": "1.0.0",
  "description": "Live event prompter software",
  "main": "dist/main.js",
  "scripts": {
    "build": "webpack --config webpack.config.js",
    "start": "npm run build && electron .",
    "pack": "electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac"
  },
  "build": {
    "appId": "com.prompter.app",
    "productName": "Prompter",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    }
  },
  "devDependencies": {
    "copy-webpack-plugin": "^12.0.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  }
}
